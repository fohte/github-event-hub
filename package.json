{
  "name": "github-event-hub",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format": "conc -m 1 pnpm:format:eslint pnpm:format:prettier",
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.5",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.2",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@fohte/service-kit": "0.1.3",
    "@hono/node-server": "2.0.4",
    "@octokit/webhooks": "14.2.0",
    "@octokit/webhooks-types": "7.6.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@sentry/node": "10.62.0",
    "@sentry/opentelemetry": "10.62.0",
    "@slack/web-api": "7.16.0",
    "hono": "4.12.25"
  }
}
